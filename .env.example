# Site gate (login password). Localhost skips cookie gate, but login still checks this.
GATE_PASSWORD=change-me

# API used after login (server-side). 9Router example — no trailing path needed (/v1 added automatically).
MINORUM_DEFAULT_API_URL=http://localhost:20128
MINORUM_DEFAULT_API_KEY=sk-your-key-here
# Optional. Prefer this model id when listed in /models (e.g. DealWithSign combo).
MINORUM_DEFAULT_MODEL=DealWithSign
