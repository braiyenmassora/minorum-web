# Site gate (login password). Localhost skips cookie gate, but login still checks this.
GATE_PASSWORD=REDACTED

# API used after login (server-side).
MINORUM_DEFAULT_API_URL=http://localhost:8080/v1
MINORUM_DEFAULT_API_KEY=sk-your-key-here
# Optional. Must exist in /models. Otherwise login picks auto/best-chat (etc).
MINORUM_DEFAULT_MODEL=auto/best-chat
